{
  "name": "agents-run",
  "version": "1.0.0",
  "description": "Local web UI for browsing AI coding session history across multiple providers",
  "type": "module",
  "bin": {
    "agents-run": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:server": "tsx watch api/index.ts --dev",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "pnpm build:server && pnpm build:web",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsup api/index.ts --format esm --dts --clean",
    "demo:gif": "pnpm build && node scripts/generate-readme-demo.mjs",
    "sync:homebrew": "bash scripts/sync-homebrew-tap.sh",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@notionhq/client": "^5.9.0",
    "@tanstack/react-virtual": "^3.13.14",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "diff": "^8.0.2",
    "hono": "^4.7.8",
    "lucide-react": "^0.562.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.7",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "playwright": "^1.58.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.0.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "conversation",
    "ai",
    "coding",
    "cli",
    "history",
    "multi-provider",
    "llm",
    "session-history",
    "viewer",
    "web-ui",
    "developer-tools",
    "claude",
    "codex",
    "gemini",
    "openai",
    "anthropic"
  ],
  "author": "ZHICHAO SUN",
  "contributors": [
    "Kamran Ahmed"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SunZhiC/agents-run.git"
  },
  "homepage": "https://github.com/SunZhiC/agents-run#readme",
  "bugs": {
    "url": "https://github.com/SunZhiC/agents-run/issues"
  }
}
